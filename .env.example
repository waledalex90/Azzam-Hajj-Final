# مشروع Azzam Hajj فقط — لا تخلط مع مشاريع Supabase أخرى.
# المصدر: Supabase Dashboard → Project (Azzam) → Settings → API
# انسخ إلى `.env.local` محلياً؛ على Vercel ضع نفس الأسماء في Environment Variables (Production).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_AZZAM_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_azzam_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_azzam_service_role_key
