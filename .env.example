# Supabase (مشروع Azzam — انسخ القيم من لوحة Supabase → Project Settings → API)
# انسخ هذا الملف إلى .env.local للتطوير المحلي؛ على Vercel أضف نفس الأسماء في Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
